# API Server Configuration

# Port for the backend server
PORT=3000

# SMTP Configuration for email sending
# For Gmail: smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# SMTP Port (usually 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Whether to use secure connection (true for SSL on port 465, false/omit for TLS on 587)
# SMTP_SECURE=false

# SMTP Username (usually your email address)
SMTP_USER=dumsender@gmail.com

# SMTP Password (for Gmail, use an app-specific password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_PASS="sgwt bnlx uksy gbtt"

# Email recipient (where translation requests are sent)
# Default: epschroeder@op.pl
EMAIL_TO=epschroeder@op.pl

# Email sender address (defaults to SMTP_USER if not set)
# EMAIL_FROM=no-reply@yourdomain.com
